# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.java text diff=java
*.ts text
*.tsx text
*.js text
*.json text
*.yml text
*.yaml text
*.md text
*.xml text
*.properties text
*.env.*.example text

# Binary file handling
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.class binary
